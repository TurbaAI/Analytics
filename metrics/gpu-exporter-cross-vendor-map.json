{
  "schemaVersion": "turba.gpu-exporter-map.v1",
  "purpose": "Normalize NVIDIA/DCGM, nvidia-smi exporter, and AMD Device Metrics Exporter GPU telemetry into Turbalance analytics families.",
  "sources": [
    {
      "name": "Grafana Nvidia GPU Metrics dashboard 14574",
      "url": "https://grafana.com/grafana/dashboards/14574-nvidia-gpu-metrics/",
      "note": "Dashboard built around Prometheus metrics from utkuozdemir/nvidia_gpu_exporter."
    },
    {
      "name": "utkuozdemir/nvidia_gpu_exporter",
      "url": "https://github.com/utkuozdemir/nvidia_gpu_exporter",
      "note": "nvidia-smi based Prometheus exporter with metric-field auto-discovery."
    },
    {
      "name": "NVIDIA DCGM Exporter",
      "url": "https://github.com/NVIDIA/dcgm-exporter",
      "note": "Prometheus exporter for NVIDIA DCGM fields, including configurable counters."
    },
    {
      "name": "AMD Device Metrics Exporter",
      "url": "https://instinct.docs.amd.com/projects/device-metrics-exporter/en/latest/",
      "note": "Prometheus-format AMD GPU and NIC metrics for HPC and AI environments."
    },
    {
      "name": "Execution-idle paper",
      "url": "https://arxiv.org/abs/2604.04745",
      "note": "Defines loaded, low-activity, high-power GPU execution-idle state."
    }
  ],
  "families": [
    {
      "key": "powerEnergy",
      "label": "Power and energy",
      "normalizedFields": ["gpuPowerWatts", "gpu_power_watts", "gpu_power_instant_watts", "turba_gpu_power_watts", "gpuEnergyConsumedMicrojoules"],
      "nvidia": ["DCGM_FI_DEV_POWER_USAGE", "DCGM_FI_DEV_POWER_USAGE_INSTANT", "nvidia_smi_power_draw_watts"],
      "amd": ["GPU_POWER_USAGE", "GPU_PACKAGE_POWER", "GPU_AVERAGE_PACKAGE_POWER", "GPU_ENERGY_CONSUMED"],
      "analyticsUse": ["executionIdleWasteWatts", "energyProjection", "powerPolicyDryRun"]
    },
    {
      "key": "activity",
      "label": "Activity",
      "normalizedFields": ["gpuUtilizationPct", "gpuSmActivePct", "gpuSmOccupancyPct", "gpuTensorActivePct", "gpuDramActivePct", "turba_gpu_activity_ratio"],
      "nvidia": ["DCGM_FI_DEV_GPU_UTIL", "DCGM_FI_PROF_SM_ACTIVE", "DCGM_FI_PROF_SM_OCCUPANCY", "DCGM_FI_PROF_PIPE_TENSOR_ACTIVE", "DCGM_FI_PROF_DRAM_ACTIVE"],
      "amd": ["GPU_GFX_ACTIVITY", "GPU_GFX_BUSY_INSTANTANEOUS", "GPU_UMC_ACTIVITY", "GPU_PROCESS_CU_OCCUPANCY"],
      "analyticsUse": ["lowActivityGate", "usefulCompute", "benchmarkComparison"]
    },
    {
      "key": "memory",
      "label": "Memory",
      "normalizedFields": ["gpuMemoryUsedPct", "gpuMemoryUsedMiB", "gpuMemoryTotalMiB", "gpu_memory_used_ratio", "turba_gpu_memory_used_ratio"],
      "nvidia": ["DCGM_FI_DEV_FB_USED", "DCGM_FI_DEV_FB_TOTAL", "DCGM_FI_DEV_FB_USED_RATIO", "DCGM_FI_PROF_DRAM_ACTIVE"],
      "amd": ["GPU_USED_VRAM", "GPU_TOTAL_VRAM", "GPU_FREE_VRAM", "GPU_USED_VISIBLE_VRAM", "GPU_VISIBLE_VRAM"],
      "analyticsUse": ["residencySignal", "memoryPressure", "capacityComparison"]
    },
    {
      "key": "thermal",
      "label": "Thermal",
      "normalizedFields": ["gpuTemperatureC", "gpu_temperature_celsius", "turba_gpu_thermal_celsius"],
      "nvidia": ["DCGM_FI_DEV_GPU_TEMP", "DCGM_FI_DEV_MEMORY_TEMP", "nvidia_smi_temperature_gpu"],
      "amd": ["GPU_EDGE_TEMPERATURE", "GPU_JUNCTION_TEMPERATURE", "GPU_MEMORY_TEMPERATURE", "GPU_HBM_TEMPERATURE"],
      "analyticsUse": ["throttleContext", "rackCoolingFingerprint", "safetyGate"]
    },
    {
      "key": "interconnect",
      "label": "Interconnect",
      "normalizedFields": ["gpuPcieTxBytesPerSecond", "gpuPcieRxBytesPerSecond", "gpuNvlinkTxBytesPerSecond", "gpuNvlinkRxBytesPerSecond", "turba_gpu_interconnect_bytes_per_second"],
      "nvidia": ["DCGM_FI_PROF_PCIE_TX_BYTES", "DCGM_FI_PROF_PCIE_RX_BYTES", "DCGM_FI_PROF_NVLINK_TX_BYTES", "DCGM_FI_PROF_NVLINK_RX_BYTES"],
      "amd": ["PCIE_BANDWIDTH", "PCIE_BIDIRECTIONAL_BANDWIDTH", "XGMI_LINK_RX", "XGMI_LINK_TX"],
      "analyticsUse": ["pciePrecursor", "nvlinkOrXgmiPrecursor", "fabricComparison"]
    },
    {
      "key": "ras",
      "label": "RAS",
      "normalizedFields": ["gpuEccErrorsTotal", "gpuXidErrorCode", "turba_gpu_ecc_errors_total"],
      "nvidia": ["DCGM_FI_DEV_ECC_SBE_AGG_TOTAL", "DCGM_FI_DEV_ECC_DBE_AGG_TOTAL", "DCGM_FI_DEV_XID_ERRORS", "DCGM_FI_DEV_FABRIC_HEALTH_MASK"],
      "amd": ["GPU_ECC_CORRECT_TOTAL", "GPU_ECC_UNCORRECT_TOTAL", "PCIE_REPLAY_COUNT", "PCIE_RECOVERY_COUNT", "PCIE_NACK_SENT_COUNT", "PCIE_NACK_RECEIVED_COUNT"],
      "analyticsUse": ["repairGate", "benchmarkValidity", "supportBundleEvidence"]
    },
    {
      "key": "clockThrottle",
      "label": "Clocks and throttle",
      "normalizedFields": ["gpuClockMHz", "gpuMemoryClockMHz", "turba_gpu_clock_mhz"],
      "nvidia": ["DCGM_FI_DEV_SM_CLOCK", "DCGM_FI_DEV_MEM_CLOCK", "DCGM_FI_DEV_CLOCK_THROTTLE_REASONS"],
      "amd": ["GPU_CLOCK", "GPU_MIN_CLOCK", "GPU_MAX_CLOCK", "GPU_VIOLATION_PPT_RESIDENCY_PERCENTAGE", "GPU_VIOLATION_HBM_THERMAL_RESIDENCY_PERCENTAGE"],
      "analyticsUse": ["sloAwareDownscale", "throttleDiagnosis", "benchmarkNormalization"]
    },
    {
      "key": "schedulerLabels",
      "label": "Scheduler labels",
      "normalizedFields": ["namespace", "podName", "containerName", "slurmJobId", "job_id"],
      "nvidia": ["namespace", "pod", "container", "job_id"],
      "amd": ["JOB_ID", "JOB_USER", "JOB_PARTITION", "CLUSTER_NAME", "NAMESPACE", "CONTAINER"],
      "analyticsUse": ["perJobAttribution", "rackComparison", "clusterComparison"]
    }
  ],
  "unitConversions": {
    "AMD_PCIE_BANDWIDTH_Mbps_to_bytes_per_second": "value * 125000",
    "AMD_PCIE_BIDIRECTIONAL_BANDWIDTH_GBps_to_bytes_per_second": "value * 1000000000",
    "ratio_to_percent": "value <= 1 ? value * 100 : value"
  },
  "comparisonGates": {
    "level1Metric": ["powerEnergy", "activity"],
    "level2OneToOne": ["powerEnergy", "activity", "memory", "thermal"],
    "level3Rack": ["powerEnergy", "activity", "memory", "thermal", "interconnect", "ras"],
    "level4Cluster": ["powerEnergy", "activity", "memory", "thermal", "interconnect", "ras", "clockThrottle"],
    "level5Fleet": ["powerEnergy", "activity", "memory", "thermal", "interconnect", "ras", "clockThrottle", "schedulerLabels"],
    "level6Global": ["powerEnergy", "activity", "memory", "thermal", "interconnect", "ras", "clockThrottle", "schedulerLabels"]
  }
}
