{
  "uid": "gb100-power-thermal",
  "title": "GB100 Power Thermal",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["gb100", "power", "thermal"],
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [
    {"name": "cluster", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_power_watts, cluster)", "includeAll": true},
    {"name": "node", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_power_watts{cluster=~\"$cluster\"}, node)", "includeAll": true},
    {"name": "gpu_uuid", "label": "GPU UUID", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_power_watts{cluster=~\"$cluster\",node=~\"$node\"}, gpu_uuid)", "includeAll": true},
    {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_tokens_per_second, namespace)", "includeAll": true},
    {"name": "pod", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_tokens_per_second{namespace=~\"$namespace\"}, pod)", "includeAll": true},
    {"name": "container", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_tokens_per_second{pod=~\"$pod\"}, container)", "includeAll": true}
  ]},
  "panels": [
    {"id": 1, "title": "Power Draw", "type": "timeseries", "gridPos": {"x": 0, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_power_watts{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "gpu_power_instant_watts{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 2, "title": "Temperature", "type": "timeseries", "gridPos": {"x": 8, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_temperature_celsius{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "gpu_memory_temperature_celsius{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 3, "title": "Violation Counters", "type": "timeseries", "gridPos": {"x": 16, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "DCGM_FI_DEV_POWER_VIOLATION{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "DCGM_FI_DEV_THERMAL_VIOLATION{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "DCGM_FI_DEV_RELIABILITY_VIOLATION{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 4, "title": "Power Limits", "type": "timeseries", "gridPos": {"x": 0, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "DCGM_FI_DEV_POWER_MGMT_LIMIT{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "DCGM_FI_DEV_ENFORCED_POWER_LIMIT{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 5, "title": "Facility Cooling", "type": "timeseries", "gridPos": {"x": 8, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "rack_inlet_coolant_temp_celsius"}, {"expr": "rack_outlet_coolant_temp_celsius"}, {"expr": "coolant_flow_liters_per_minute"}]},
    {"id": 6, "title": "External Thermal Capability", "type": "table", "gridPos": {"x": 16, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gb100_metric_capability{metric=~\"coolant_temperature|gpu_temperature_celsius|gpu_memory_temperature_celsius\"}"}]}
  ]
}
