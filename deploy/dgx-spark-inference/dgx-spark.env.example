# Copy to dgx-spark.env on each DGX Spark host and fill only the values needed
# for the backend you plan to run. Do not commit real NGC, HF, or API keys.

DGX_HEAD_IP=192.168.10.20
DGX_WORKER_IP=192.168.10.21
DGX_PUBLIC_HEAD_IP=192.168.10.20

# Dedicated CX7/RDMA subnet for multi-node vLLM/NCCL traffic.
VLLM_MN_IF_NAME=enp1s0f1np1
VLLM_MN_HEAD_IP=192.168.100.10
VLLM_MN_WORKER_IP=192.168.100.11

RAY_VERSION=2.55.1
RAY_PORT=6379
RAY_DASHBOARD_PORT=8265
RAY_CLIENT_PORT=10001
RAY_NUM_GPUS=1
RAY_TEMP_DIR=/tmp/ray

OPENAI_API_PORT=8355
OPENAI_API_KEY=local-dev-key
OPENAI_API_BASE_URL=http://192.168.10.20:8355/v1

OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPEN_WEBUI_PORT=3001
OPEN_WEBUI_BIND_ADDR=0.0.0.0
OPEN_WEBUI_VOLUME=open-webui
WEBUI_AUTH=true
ENABLE_OLLAMA_API=true
OLLAMA_BASE_URL=http://192.168.10.20:8355

# Immediate local-model fallback. This exposes Ollama's OpenAI-compatible API
# at OPENAI_API_BASE_URL until vLLM or NIM/TRT-LLM is launched on that port.
OLLAMA_OPENAI_PROXY_IMAGE=alpine/socat:latest
OLLAMA_OPENAI_PROXY_CONTAINER=dgx-ollama-openai-proxy
OLLAMA_OPENAI_PROXY_PORT=8355
OLLAMA_UPSTREAM_HOST=127.0.0.1
OLLAMA_UPSTREAM_PORT=11434

# vLLM backend. NVIDIA's DGX Spark playbook uses this NGC image.
VLLM_IMAGE=nvcr.io/nvidia/vllm:25.11-py3
VLLM_CONTAINER_NAME=dgx-vllm-openai
VLLM_RAY_HEAD_CONTAINER=dgx-vllm-ray-head
VLLM_RAY_WORKER_CONTAINER=dgx-vllm-ray-worker
VLLM_CONTAINER_SHM_SIZE=32g
MODEL_ID=
SERVED_MODEL_NAME=
HF_TOKEN=
HF_HOME=/home/user/dgx-spark-inference/hf-cache
VLLM_TENSOR_PARALLEL_SIZE=2
VLLM_EXTRA_ARGS=

# Experimental 405B path. NVIDIA documents this as testing-only because
# the model has very little memory headroom on two Sparks.
VLLM_405B_MODEL=hugging-quants/Meta-Llama-3.1-405B-Instruct-AWQ-INT4
VLLM_405B_SERVED_MODEL_NAME=llama-3.1-405b-awq-int4
VLLM_405B_TENSOR_PARALLEL_SIZE=2
VLLM_405B_MAX_MODEL_LEN=64
VLLM_405B_GPU_MEMORY_UTILIZATION=0.88
VLLM_405B_MAX_NUM_SEQS=1
VLLM_405B_MAX_NUM_BATCHED_TOKENS=64

# NVIDIA NIM/TRT-LLM backend. Use the image/profile provided by NGC/NIM.
NIM_IMAGE=
NIM_CONTAINER_NAME=dgx-nim
NGC_API_KEY=
NIM_SERVER_PORT=8355
NIM_PRIMARY_NODE=
NIM_NODE_MANAGER_PORT=20000
NIM_DOCKER_ARGS=
NIM_EXTRA_ENV=
NIM_EXTRA_ARGS=
