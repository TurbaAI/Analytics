{
  "uid": "gb100-interconnect",
  "title": "GB100 Interconnect",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["gb100", "nvlink", "c2c", "fabric"],
  "time": {"from": "now-1h", "to": "now"},
  "templating": {"list": [
    {"name": "cluster", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_nvlink_tx_bytes_per_second, cluster)", "includeAll": true},
    {"name": "node", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_nvlink_tx_bytes_per_second{cluster=~\"$cluster\"}, node)", "includeAll": true},
    {"name": "gpu_uuid", "label": "GPU UUID", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gpu_nvlink_tx_bytes_per_second{cluster=~\"$cluster\",node=~\"$node\"}, gpu_uuid)", "includeAll": true},
    {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_nccl_allreduce_bytes_per_second, namespace)", "includeAll": true},
    {"name": "pod", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_nccl_allreduce_bytes_per_second{namespace=~\"$namespace\"}, pod)", "includeAll": true},
    {"name": "container", "type": "query", "datasource": {"type": "prometheus", "uid": "prometheus"}, "query": "label_values(gb100_app_nccl_allreduce_bytes_per_second{pod=~\"$pod\"}, container)", "includeAll": true}
  ]},
  "panels": [
    {"id": 1, "title": "NVLink Throughput", "type": "timeseries", "gridPos": {"x": 0, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_nvlink_tx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "gpu_nvlink_rx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 2, "title": "PCIe Throughput", "type": "timeseries", "gridPos": {"x": 8, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_pcie_tx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "gpu_pcie_rx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 3, "title": "C2C Throughput", "type": "timeseries", "gridPos": {"x": 16, "y": 0, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_c2c_tx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}, {"expr": "gpu_c2c_rx_bytes_per_second{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 4, "title": "NVLink Errors", "type": "timeseries", "gridPos": {"x": 0, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gpu_nvlink_errors_total{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"}"}]},
    {"id": 5, "title": "Fabric Health", "type": "stat", "gridPos": {"x": 8, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "max(DCGM_FI_DEV_FABRIC_HEALTH_MASK{cluster=~\"$cluster\",gpu_uuid=~\"$gpu_uuid\"})"}]},
    {"id": 6, "title": "App NCCL Throughput", "type": "timeseries", "gridPos": {"x": 16, "y": 7, "w": 8, "h": 7}, "datasource": {"type": "prometheus", "uid": "prometheus"}, "targets": [{"expr": "gb100_app_nccl_allreduce_bytes_per_second{namespace=~\"$namespace\",pod=~\"$pod\",container=~\"$container\"}"}, {"expr": "gb100_app_nccl_allgather_bytes_per_second{namespace=~\"$namespace\",pod=~\"$pod\",container=~\"$container\"}"}, {"expr": "gb100_app_nccl_reducescatter_bytes_per_second{namespace=~\"$namespace\",pod=~\"$pod\",container=~\"$container\"}"}]}
  ]
}
