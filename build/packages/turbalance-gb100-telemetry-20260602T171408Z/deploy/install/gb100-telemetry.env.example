# turbalance GB100/GB200 telemetry install configuration.
# Copy to deploy/install/gb100-telemetry.env on the installed host.

# DCGM Exporter collection interval in milliseconds. Very aggressive polling can add overhead.
DCGM_EXPORTER_INTERVAL=1000

# Leave blank for embedded nv-hostengine. Set host:port for an existing remote nv-hostengine.
DCGM_REMOTE_HOSTENGINE_INFO=

# Optional NVML confidential-computing collector. It fails soft when APIs are unavailable.
ENABLE_NVML_COLLECTOR=false

# Docker Grafana credentials. Change before exposing outside localhost.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Static mode ports used by install.sh --mode static.
TURBALANCE_APP_PORT=8000
GB100_APP_COLLECTOR_PORT=9500
