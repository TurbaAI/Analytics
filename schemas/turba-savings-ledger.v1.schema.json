{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://turba.analytics/schemas/turba-savings-ledger.v1.schema.json",
  "title": "turbalance verified savings ledger entry",
  "type": "object",
  "required": [
    "id",
    "actionId",
    "scope",
    "status",
    "metric",
    "baseline",
    "result",
    "deltaGpuHours",
    "deltaDollars",
    "confidence",
    "attribution",
    "evidenceRef"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "actionId": { "type": "string", "minLength": 1 },
    "actionTitle": { "type": "string" },
    "category": { "type": "string" },
    "scope": {
      "type": "object",
      "required": ["type", "key"],
      "properties": {
        "type": {
          "enum": ["job", "model", "team", "tenant", "cluster", "account"]
        },
        "key": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": ["proposed", "accepted", "applied", "verified", "rejected", "expired"]
    },
    "metric": {
      "type": "string",
      "minLength": 1
    },
    "baseline": { "$ref": "#/$defs/snapshotMetric" },
    "result": { "$ref": "#/$defs/snapshotMetric" },
    "deltaGpuHours": { "type": "number" },
    "deltaDollars": { "type": "number" },
    "predictedGpuHours": { "type": "number" },
    "predictedDollars": { "type": "number" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "attribution": { "enum": ["measured", "modeled"] },
    "appliedAt": { "type": "string" },
    "verifiedAt": { "type": "string" },
    "evidenceRef": { "type": "string" }
  },
  "$defs": {
    "snapshotMetric": {
      "type": "object",
      "required": ["value", "window", "snapshotId"],
      "properties": {
        "value": { "type": "number" },
        "window": { "type": "string" },
        "snapshotId": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
