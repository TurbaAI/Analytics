# Copy this file outside source control and replace every value before go-live.
TURBALANCE_IMAGE_REGISTRY=ghcr.io/acme/turbalance
TURBALANCE_IMAGE_TAG=2026.06.04.1
TURBALANCE_NAMESPACE=turbalance-lakehouse

TURBALANCE_LAKE_ROOT=s3://acme-turbalance-prod/turbalance/lakehouse
TURBALANCE_API_JWT_ISSUER=https://issuer.acme.internal
TURBALANCE_API_JWT_AUDIENCE=turbalance-api

TURBALANCE_DISCOVERY_CERTIFICATE_MODE=spire
TURBALANCE_TRUSTED_SPIFFE_PREFIX=spiffe://turbalance.local/

TURBALANCE_QUEUE_GATEWAY_BACKEND=kafka
TURBALANCE_QUEUE_GATEWAY_BROKER_URL=kafka.prod.svc.cluster.local:9092
TURBALANCE_QUEUE_GATEWAY_TOPIC=turbalance.collector.telemetry
TURBALANCE_DISCOVERY_DATABASE_URL=postgresql://turbalance:replace-outside-source-control@postgres.acme.internal:5432/turbalance
TURBALANCE_COLLECTOR_TENANT_CREDENTIALS=tenant-a:replace-outside-source-control:replace-outside-source-control:tenant-a-collector
TURBALANCE_COLLECTOR_TENANT_CREDENTIALS_FILE=/secure/path/collector-tenant-credentials

TURBALANCE_OTEL_BACKEND_OTLP_ENDPOINT=https://otel-collector.acme.internal/v1/traces
TURBALANCE_ALERT_WEBHOOK_URL=https://alerts.acme.internal/turbalance

# Secret-store sync inputs. Keep real values outside source control.
# Prefer tenant-scoped collector credentials for production: tenant:bearer-token:hmac-secret[:subject].
# Legacy single collector credentials are accepted only for lab/sandbox migration.
# TURBALANCE_COLLECTOR_TOKEN=
# TURBALANCE_COLLECTOR_HMAC_SECRET=
# TURBALANCE_DISCOVERY_ENROLLMENT_TOKEN=
# TURBALANCE_API_TOKENS=tenant-a:viewer-token:viewer:tenant-a-viewer
# TURBALANCE_API_JWKS_FILE=/secure/path/api-jwks.json
# TURBALANCE_AGENT_CLIENT_CA_FILE=/secure/path/agent-client-ca.pem
# TURBALANCE_COLLECTOR_QUEUE_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
# AWS_ENDPOINT_URL=https://s3.us-west-2.amazonaws.com
# TURBALANCE_S3_SCHEME=s3
# TURBALANCE_OTEL_BACKEND_AUTHORIZATION=
# TURBALANCE_ALERT_SLACK_WEBHOOK_URL=
# TURBALANCE_ALERT_PAGERDUTY_ROUTING_KEY=
# TURBALANCE_CONSUL_TOKEN=

# Optional live rollout inputs.
TURBALANCE_TERRAFORM_DIR=ops/terraform/lakehouse/aws
TURBALANCE_EBPF_HOSTS_FILE=ops/lakehouse-ebpf-hosts.example.json
TURBALANCE_BURN_IN_REQUESTS=25
TURBALANCE_BURN_IN_CONCURRENCY=4
# TURBALANCE_API_URL=https://turbalance-api.acme.internal
# TURBALANCE_COLLECTOR_URL=https://collector.acme.internal
# TURBALANCE_GRAFANA_URL=https://grafana.acme.internal
# TURBALANCE_OTEL_COLLECTOR_METRICS_URL=https://otel-collector.acme.internal/metrics
# TURBALANCE_PROMETHEUS_URL=https://prometheus.acme.internal
