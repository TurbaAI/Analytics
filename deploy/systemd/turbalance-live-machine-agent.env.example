# Copy to /etc/turbalance/live-machine-agent.env on each SPARK, Pi, or NUC host.
TURBALANCE_TENANT_ID=dgx-lab
TURBALANCE_HOST_ID=
TURBALANCE_AGENT_ID=live-machine-push
TURBALANCE_COLLECTOR_URL=http://192.168.10.30:8801/v1/source-bundles
TURBALANCE_MACHINE_DEMO_URL=http://192.168.10.30:8000
TURBALANCE_AGENT_LOOP_MS=1000
TURBALANCE_AGENT_POST_TIMEOUT_MS=10000
TURBALANCE_AGENT_SEQUENCE_PATH=/var/lib/turbalance/live-machine-agent/sequence-no
TURBALANCE_AGENT_SPOOL_DIR=/var/spool/turbalance/live-machine-agent
TURBALANCE_AGENT_MAX_REPLAY=25
TURBALANCE_COLLECTOR_TOKEN=
TURBALANCE_COLLECTOR_HMAC_SECRET=
TURBALANCE_GPU_BACKEND=auto
TURBALANCE_GPUSTAT_BIN=
TURBALANCE_DGX_INTERCONNECT_INTERFACE=enp1s0f1np1
TURBALANCE_DGX_INTERCONNECT_SUBNET_PREFIX=192.168.100.
TURBALANCE_MACHINE_BENCHMARKS=0
TURBALANCE_PI_BENCHMARKS=0
TURBALANCE_BENCHMARK_TTL_MS=900000
TURBALANCE_BENCHMARK_DURATION_MS=450
TURBALANCE_BENCHMARK_BUFFER_MIB=8
TURBALANCE_BENCHMARK_DISK_MIB=16
